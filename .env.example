# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Flask secret key – change to a long random string in production
SECRET_KEY=change-me-in-production

# SQLite database path (relative to the instance/ folder)
# DATABASE_URL=sqlite:///textbyte.db

# ─── Microsoft Entra ID (Azure AD) App Registration ───────────────────────────
# Follow the steps in README.md to create your App Registration, then paste the
# values below.

AZURE_CLIENT_ID=your-application-client-id
AZURE_CLIENT_SECRET=your-client-secret-value
AZURE_TENANT_ID=common

# The redirect URI must exactly match the one registered in Azure Portal.
# For local development:
AZURE_REDIRECT_URI=http://localhost:5000/auth/callback
